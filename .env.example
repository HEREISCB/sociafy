# =============================================================
# Sociafy — environment configuration
# =============================================================
# Copy this file to .env.local and fill values.
# In stub mode (no keys), the app runs end-to-end with fake data.
# Each section flips to real behavior once its keys are present.

# ----- App -----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Random 32+ char strings.
INTERNAL_API_SECRET=dev-secret-change-me
CRON_SECRET=dev-cron-secret-change-me

# ----- Clerk (auth) -----
# Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional path overrides — defaults are /sign-in and /sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/onboarding

# ----- Postgres (any provider — Supabase pooler URL / Neon / etc.) -----
DATABASE_URL=

# ----- Anthropic (compose + agent) -----
ANTHROPIC_API_KEY=

# ----- Cloudflare R2 (media storage) -----
# Cloudflare dashboard → R2 → Manage R2 API Tokens → Create API Token (Object Read & Write)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public base URL for served objects — either the bucket's public r2.dev URL or your custom domain.
# Example: https://pub-<hash>.r2.dev   or   https://media.sociafy.app
NEXT_PUBLIC_R2_PUBLIC_URL_BASE=

# ----- OAuth / posting credentials -----
# X (Twitter) — https://developer.x.com  (OAuth 2.0 + offline.access)
X_CLIENT_ID=
X_CLIENT_SECRET=

# LinkedIn — https://developer.linkedin.com  (OIDC + w_member_social)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Meta (covers Instagram + Facebook) — https://developers.facebook.com
META_APP_ID=
META_APP_SECRET=

# TikTok — https://developers.tiktok.com
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Google (covers YouTube) — https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
