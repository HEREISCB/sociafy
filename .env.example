# =============================================================
# Sociafy — environment configuration
# =============================================================
# Copy this file to .env.local and fill values.
# In stub mode (no keys), the app runs end-to-end with fake data.
# Each section flips to real behavior once its keys are present.

# ----- App -----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Random 32+ char string. Used to sign internal tokens and cron requests.
INTERNAL_API_SECRET=dev-secret-change-me

# ----- Supabase (auth + database + storage) -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string for Drizzle migrations (Supabase -> Project Settings -> Database -> Connection string -> URI).
# Use the "Session" pooler URL for migrations and the "Transaction" pooler URL for runtime.
DATABASE_URL=

# ----- Anthropic (compose + agent) -----
ANTHROPIC_API_KEY=

# ----- OAuth / posting credentials -----
# X (Twitter) — https://developer.x.com  (OAuth 2.0, with offline.access for refresh tokens)
X_CLIENT_ID=
X_CLIENT_SECRET=

# LinkedIn — https://developer.linkedin.com  (Sign In with LinkedIn v2 + w_member_social)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Meta (covers Instagram + Facebook) — https://developers.facebook.com  (Graph API)
META_APP_ID=
META_APP_SECRET=

# TikTok — https://developers.tiktok.com  (Login Kit + Content Posting API)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Google (covers YouTube) — https://console.cloud.google.com  (OAuth 2.0 + YouTube Data API v3)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----- Cron -----
# Vercel Cron uses a shared secret in the Authorization header.
CRON_SECRET=dev-cron-secret-change-me
